{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "maxLength": 60
    },
    "description": {
      "type": "string"
    },
    "coverImage": {
      "type": "object",
      "properties": {
        "alt": {
          "type": "string"
        },
        "src": {
          "type": "string"
        }
      },
      "required": [
        "alt",
        "src"
      ]
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "ogImage": {
      "type": "string"
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "publishDate": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "string",
          "format": "date-time"
        }
      ]
    },
    "updatedDate": {
      "type": "string"
    },
    "pinned": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "publishDate"
  ]
}